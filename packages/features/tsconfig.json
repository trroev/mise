{
  "extends": "@mise/tsconfig/library.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "payload": ["./node_modules/payload"],
      "@mise/features/components/*": ["./src/components/*/index.ts"],
      "@mise/features/utils/*": ["./src/utils/*/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
