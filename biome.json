{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next"
  ],
  "files": {
    "includes": [
      "!**/payload-types.ts",
      "!**/importMap.js",
      "!**/app/(payload)"
    ]
  },
  "javascript": {
    "formatter": {
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        },
        "useConsistentArrayType": {
          "level": "error",
          "options": {
            "syntax": "generic"
          }
        },
        "noDefaultExport": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/**/app/**/*.ts",
        "apps/**/app/**/*.tsx",
        "apps/**/middleware.ts",
        "apps/storybook/.storybook/**/*.ts",
        "apps/storybook/.storybook/**/*.tsx",
        "**/*.stories.ts",
        "**/*.stories.tsx",
        "**/*.config.ts",
        "**/*.config.js",
        "**/*.config.mjs",
        "**/*.config.cjs"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/storybook/.storybook/preview.tsx",
        "packages/ui/src/components/*/index.ts",
        "packages/ui/src/utils/*/index.ts",
        "packages/features/src/components/*/index.ts",
        "packages/features/src/utils/*/index.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    }
  ]
}
