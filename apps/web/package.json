{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm with-env next build",
    "dev": "pnpm with-env next dev --turbopack",
    "start": "pnpm with-env next start",
    "typecheck": "next typegen && tsc --noEmit",
    "with-env": "dotenvx run --convention=nextjs --",
    "generate:types": "pnpm with-env payload generate:types",
    "generate:importmap": "pnpm with-env payload generate:importmap",
    "postinstall": "if [ \"$CI\" != \"true\" ]; then pnpm generate:types && pnpm generate:importmap; fi"
  },
  "dependencies": {
    "@mise/auth": "workspace:*",
    "@mise/env": "workspace:*",
    "@mise/payload": "workspace:*",
    "@mise/tailwind": "workspace:*",
    "@mise/types": "workspace:*",
    "@mise/ui": "workspace:*",
    "@mise/utils": "workspace:*",
    "@payloadcms/db-mongodb": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@remixicon/react": "^4.9.0",
    "better-auth": "^1.2.8",
    "minisearch": "^7.2.0",
    "next": "16.2.4",
    "payload": "^3.84.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "ts-pattern": "^5.9.0"
  },
  "devDependencies": {
    "@mise/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "tailwindcss": "^4.2.4",
    "typescript": "5.9.2"
  }
}
