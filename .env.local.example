# ── Database ────────────────────────────────────────────────────────────────────
# Local development (requires Docker — run `docker compose up -d` first):
MONGODB_URI=mongodb://localhost:27017/mise
# Production / preview (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mise?retryWrites=true&w=majority

# ── Build ───────────────────────────────────────────────────────────────────────
# Set to 1 in CI to skip @t3-oss/env-nextjs validation during builds that don't
# have access to secrets (e.g. preview builds, static analysis):
# SKIP_ENV_VALIDATION=1

# ── Auth ─────────────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of the app (used by BetterAuth for redirects and CSRF protection)
BETTER_AUTH_URL=http://localhost:3000
