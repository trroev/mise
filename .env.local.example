# ─── Database ────────────────────────────────────────────────────────────────
# Local development (requires Docker: docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/mise
# Production / preview (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mise

# ─── Payload CMS ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Auth (BetterAuth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
