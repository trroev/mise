# ─── Database ────────────────────────────────────────────────────────────────
# Local development (requires Docker: docker compose up -d)
MONGODB_URI=mongodb://localhost:27017/mise

# To point local dev at the staging Atlas database instead, replace the line
# above with the staging connection string. Get the URI from 1Password
# ("Mise — MongoDB Atlas (staging)"). Atlas URIs follow this format:
#
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<cluster>
#
# Use database `mise_staging` with user `mise_staging_user`. Production
# (`mise_production` / `mise_production_user`) is set per-environment in Vercel
# and should never be used locally.

# ─── Payload CMS ─────────────────────────────────────────────────────────────
PAYLOAD_SECRET=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Auth (BetterAuth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
